<% content_for :title, "Iniciar sesión" %>

<div class="w-full max-w-sm">
  <%# Page heading %>
  <div class="mb-8 text-center">
    <div class="mb-3 text-4xl" aria-hidden="true">🫓</div>
    <h1 class="text-2xl font-bold text-gray-900">Bienvenido de vuelta</h1>
    <p class="mt-2 text-sm text-gray-500">Accede al panel de administración</p>
  </div>

  <%# Sign-in card %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { novalidate: true }) do |f| %>
        <div class="space-y-4">
          <%# Email %>
          <div>
            <%= f.label :email, "Correo electrónico",
                  class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  placeholder: "admin@tiendaempanadas.com",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
          </div>

          <%# Password %>
          <div>
            <div class="mb-1.5 flex items-center justify-between">
              <%= f.label :password, "Contraseña",
                    class: "block text-sm font-medium text-gray-700" %>
              <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
                <%= link_to "¿Olvidaste tu contraseña?",
                      new_password_path(resource_name),
                      class: "text-xs font-medium text-primary-600 hover:text-primary-700 transition-colors" %>
              <% end %>
            </div>
            <%= f.password_field :password,
                  autocomplete: "current-password",
                  placeholder: "••••••••",
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
          </div>

          <%# Remember me %>
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me,
                    class: "h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer" %>
              <%= f.label :remember_me, "Recordar sesión",
                    class: "text-sm text-gray-600 cursor-pointer select-none" %>
            </div>
          <% end %>

          <%# Submit %>
          <%= f.submit "Iniciar sesión",
                class: "mt-2 w-full cursor-pointer rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
