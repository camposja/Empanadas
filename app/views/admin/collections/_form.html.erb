<%= form_with(model: [:admin, collection], class: "space-y-6") do |form| %>
  <%# Validation errors %>
  <% if collection.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <div class="flex gap-3">
        <span class="shrink-0 text-red-500">⚠</span>
        <div>
          <p class="text-sm font-semibold text-red-800">
            <%= collection.errors.count == 1 ? "1 error impidió guardar esta colección:" : "#{collection.errors.count} errores impidieron guardar esta colección:" %>
          </p>
          <ul class="mt-2 list-disc pl-5 text-sm text-red-700 space-y-1">
            <% collection.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Core info %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Información de la colección</h2>
    </div>
    <div class="p-6 space-y-5">
      <div>
        <%= form.label :name, "Nombre *", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :name,
              placeholder: "Navidad, Tradicionales, Temporada...",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div>
        <%= form.label :slug, "Slug (URL)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :slug,
              placeholder: "navidad, tradicionales...",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 font-mono placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        <p class="mt-1.5 text-xs text-gray-500">
          Dejar en blanco para auto-generar a partir del nombre. Solo letras, números y guiones.
        </p>
      </div>

      <div>
        <%= form.label :description, "Descripción", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_area :description,
              rows: 3,
              placeholder: "Describe esta colección de empanadas...",
              class: "block w-full resize-none rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>
  </div>

  <%# Display settings %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Configuración de visualización</h2>
    </div>
    <div class="p-6 space-y-5">
      <div class="flex items-start gap-3">
        <%= form.check_box :active,
              class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer" %>
        <div>
          <%= form.label :active, "Colección activa",
                class: "text-sm font-medium text-gray-700 cursor-pointer" %>
          <p class="mt-0.5 text-xs text-gray-500">Visible en la tienda pública y en los filtros.</p>
        </div>
      </div>
      <div>
        <%= form.label :position, "Orden de visualización", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.number_field :position,
              min: 0,
              placeholder: "0",
              class: "block w-32 rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        <p class="mt-1.5 text-xs text-gray-500">Número menor aparece primero. Se usa para ordenar en el menú.</p>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-between">
    <%= link_to local_assigns[:cancel_path] || admin_collections_path,
          class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
      ← Cancelar
    <% end %>
    <%= form.submit class: "inline-flex cursor-pointer items-center rounded-lg bg-primary-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" %>
  </div>
<% end %>
