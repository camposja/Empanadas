<% content_for :title, @collection.name %>

<div class="max-w-3xl">
  <%# Breadcrumb + header %>
  <div class="mb-6">
    <nav class="mb-1 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Colecciones", admin_collections_path, class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-gray-900"><%= @collection.name %></span>
    </nav>
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900"><%= @collection.name %></h1>
        <% if @collection.active %>
          <span class="inline-flex rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-800">Activa</span>
        <% else %>
          <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-500">Inactiva</span>
        <% end %>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to "Editar", edit_admin_collection_path(@collection),
              class: "inline-flex items-center rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-600" %>
        <%= button_to "Eliminar", [:admin, @collection],
              method: :delete,
              class: "inline-flex cursor-pointer items-center rounded-lg bg-white px-4 py-2.5 text-sm font-medium text-red-600 shadow-sm ring-1 ring-inset ring-red-200 transition-colors hover:bg-red-50",
              data: { turbo_confirm: "¿Eliminar \"#{@collection.name}\"? Se eliminarán también sus #{@collection.products.count} productos. Esta acción no se puede deshacer." } %>
      </div>
    </div>
  </div>

  <%# Collection detail card %>
  <div class="mb-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Información de la colección</h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Nombre</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @collection.name %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Slug</dt>
        <dd class="col-span-2 font-mono text-sm text-gray-500"><%= @collection.slug %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Descripción</dt>
        <dd class="col-span-2 whitespace-pre-wrap text-sm text-gray-900"><%= @collection.description.presence || "—" %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Posición</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @collection.position %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Creada</dt>
        <dd class="col-span-2 text-sm text-gray-500"><%= @collection.created_at.strftime("%d/%m/%Y a las %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Products in this collection %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">
        Productos (<%= @products.count %>)
      </h2>
      <%= link_to "Nuevo producto", new_admin_product_path,
            class: "text-xs font-medium text-primary-600 hover:text-primary-700 transition-colors" %>
    </div>
    <% if @products.any? %>
      <table class="min-w-full divide-y divide-gray-100">
        <thead>
          <tr class="bg-gray-50">
            <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Producto</th>
            <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Precio</th>
            <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Estado</th>
            <th scope="col" class="relative px-5 py-2.5"><span class="sr-only">Acciones</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @products.each do |product| %>
            <tr class="transition-colors hover:bg-gray-50">
              <td class="px-5 py-3">
                <div class="flex items-center gap-2">
                  <div class="h-8 w-8 shrink-0 overflow-hidden rounded bg-primary-50">
                    <% if product.photos.attached? %>
                      <%= image_tag product.photos.first.variant(resize_to_fill: [32, 32]),
                            class: "h-full w-full object-cover", alt: product.name %>
                    <% else %>
                      <span class="flex h-full w-full items-center justify-center text-sm">🫓</span>
                    <% end %>
                  </div>
                  <p class="text-sm font-medium text-gray-900"><%= product.name %></p>
                </div>
              </td>
              <td class="whitespace-nowrap px-5 py-3 text-sm text-gray-700">
                <%= product.price ? "Q #{product.price}" : "—" %>
              </td>
              <td class="whitespace-nowrap px-5 py-3">
                <div class="flex gap-1">
                  <% if product.active %>
                    <span class="inline-flex rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-800">Activo</span>
                  <% else %>
                    <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">Inactivo</span>
                  <% end %>
                  <% if product.featured %>
                    <span class="inline-flex rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800">★</span>
                  <% end %>
                </div>
              </td>
              <td class="whitespace-nowrap px-5 py-3 text-right">
                <div class="flex items-center justify-end gap-1.5">
                  <%= link_to "Ver", [:admin, product],
                        class: "rounded bg-white px-2 py-1 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 transition-colors hover:bg-gray-50" %>
                  <%= link_to "Editar", edit_admin_product_path(product),
                        class: "rounded bg-white px-2 py-1 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 transition-colors hover:bg-gray-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="py-10 text-center">
        <p class="text-sm text-gray-500">Esta colección no tiene productos aún.</p>
        <%= link_to "Agregar producto", new_admin_product_path,
              class: "mt-3 inline-block text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors" %>
      </div>
    <% end %>
  </div>

  <div class="mt-4">
    <%= link_to "← Volver a colecciones", admin_collections_path,
          class: "text-sm font-medium text-gray-600 transition-colors hover:text-primary-600" %>
  </div>
</div>
