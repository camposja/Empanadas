<% content_for :title, "Colecciones" %>

<div>
  <%# Header %>
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Colecciones</h1>
      <p class="mt-1 text-sm text-gray-500">
        <%= @collections.count %> colección<%= @collections.count == 1 ? "" : "es" %> en total
      </p>
    </div>
    <%= link_to new_admin_collection_path,
          class: "inline-flex items-center gap-1.5 rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-600 self-start" do %>
      <span aria-hidden="true">+</span> Nueva colección
    <% end %>
  </div>

  <% if @collections.any? %>
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Nombre</th>
              <th scope="col" class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Slug</th>
              <th scope="col" class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-500">Productos</th>
              <th scope="col" class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-500">Activa</th>
              <th scope="col" class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-500">Posición</th>
              <th scope="col" class="relative px-5 py-3"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @collections.each do |collection| %>
              <tr class="transition-colors hover:bg-gray-50">
                <td class="whitespace-nowrap px-5 py-4">
                  <p class="text-sm font-medium text-gray-900"><%= collection.name %></p>
                  <% if collection.description.present? %>
                    <p class="mt-0.5 text-xs text-gray-500 line-clamp-1"><%= collection.description %></p>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-5 py-4 font-mono text-xs text-gray-500"><%= collection.slug %></td>
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-900">
                  <%= collection.products.count %>
                </td>
                <td class="whitespace-nowrap px-5 py-4 text-center">
                  <% if collection.active %>
                    <span class="inline-flex rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">Sí</span>
                  <% else %>
                    <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-500">No</span>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-500"><%= collection.position %></td>
                <td class="whitespace-nowrap px-5 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to "Ver", [:admin, collection],
                          class: "rounded-md bg-white px-2.5 py-1.5 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 transition-colors hover:bg-gray-50" %>
                    <%= link_to "Editar", edit_admin_collection_path(collection),
                          class: "rounded-md bg-white px-2.5 py-1.5 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 transition-colors hover:bg-gray-50" %>
                    <%= button_to "Eliminar", [:admin, collection],
                          method: :delete,
                          class: "rounded-md bg-white px-2.5 py-1.5 text-xs font-medium text-red-600 shadow-sm ring-1 ring-inset ring-red-200 transition-colors hover:bg-red-50 cursor-pointer",
                          data: { turbo_confirm: "¿Eliminar \"#{collection.name}\"? Se eliminarán también sus productos. Esta acción no se puede deshacer." } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-xl border-2 border-dashed border-gray-200 bg-white py-16 text-center">
      <p class="mb-3 text-4xl">📂</p>
      <h3 class="text-sm font-semibold text-gray-900">No hay colecciones</h3>
      <p class="mt-1 text-sm text-gray-500">Crea tu primera colección para organizar los productos.</p>
      <div class="mt-6">
        <%= link_to "Nueva colección", new_admin_collection_path,
              class: "inline-flex items-center rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-600" %>
      </div>
    </div>
  <% end %>
</div>
