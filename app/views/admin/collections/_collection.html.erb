<div id="<%= dom_id collection %>" class="space-y-0.5">
  <div class="flex items-center gap-2">
    <p class="text-sm font-medium text-gray-900"><%= collection.name %></p>
    <% unless collection.active %>
      <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">Inactiva</span>
    <% end %>
  </div>
  <p class="font-mono text-xs text-gray-400"><%= collection.slug %></p>
</div>
