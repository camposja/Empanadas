<% content_for :title, "Editar — #{@product.name}" %>

<div class="max-w-2xl">
  <div class="mb-6">
    <nav class="mb-1 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Productos", admin_products_path, class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <%= link_to @product.name, [:admin, @product], class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-gray-900">Editar</span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900">Editar producto</h1>
  </div>

  <%= render "form", product: @product, cancel_path: [:admin, @product] %>
</div>
