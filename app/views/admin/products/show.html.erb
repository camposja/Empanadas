<% content_for :title, @product.name %>

<div class="max-w-3xl">
  <%# Breadcrumb + header %>
  <div class="mb-6">
    <nav class="mb-1 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Productos", admin_products_path, class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-gray-900"><%= @product.name %></span>
    </nav>
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="text-2xl font-bold text-gray-900"><%= @product.name %></h1>
      <div class="flex items-center gap-2">
        <%= link_to "Editar", edit_admin_product_path(@product),
              class: "inline-flex items-center rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-600" %>
        <%= button_to "Eliminar", [:admin, @product],
              method: :delete,
              class: "inline-flex cursor-pointer items-center rounded-lg bg-white px-4 py-2.5 text-sm font-medium text-red-600 shadow-sm ring-1 ring-inset ring-red-200 transition-colors hover:bg-red-50",
              data: { turbo_confirm: "¿Eliminar \"#{@product.name}\"? Esta acción no se puede deshacer." } %>
      </div>
    </div>
  </div>

  <%# Status badges %>
  <div class="mb-4 flex flex-wrap gap-2">
    <% if @product.active %>
      <span class="inline-flex rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800">✓ Activo</span>
    <% else %>
      <span class="inline-flex rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-500">Inactivo</span>
    <% end %>
    <% if @product.featured %>
      <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800">★ Destacado</span>
    <% end %>
    <% if @product.seasonal %>
      <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">🍂 De temporada</span>
    <% end %>
  </div>

  <%# Photo gallery %>
  <% if @product.photos.attached? %>
    <div class="mb-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
        <h2 class="text-sm font-semibold text-gray-700">Fotos (<%= @product.photos.count %>)</h2>
      </div>
      <div class="p-4">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
          <% @product.photos.each do |photo| %>
            <%= image_tag photo.variant(resize_to_fill: [200, 150]),
                  class: "aspect-[4/3] w-full rounded-lg object-cover shadow-sm ring-1 ring-gray-200",
                  alt: @product.name %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Detail card %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Información del producto</h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Nombre</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @product.name %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Colección</dt>
        <dd class="col-span-2 text-sm text-gray-900">
          <%= link_to @product.collection.name, [:admin, @product.collection],
                class: "text-primary-600 hover:text-primary-700 transition-colors" %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Precio</dt>
        <dd class="col-span-2 text-sm font-semibold text-gray-900">
          <%= @product.price ? "Q #{format('%.2f', @product.price)}" : "—" %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Slug</dt>
        <dd class="col-span-2 font-mono text-sm text-gray-500"><%= @product.slug %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Descripción</dt>
        <dd class="col-span-2 whitespace-pre-wrap text-sm text-gray-900"><%= @product.description.presence || "—" %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Registrado</dt>
        <dd class="col-span-2 text-sm text-gray-500"><%= @product.created_at.strftime("%d/%m/%Y a las %H:%M") %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Actualizado</dt>
        <dd class="col-span-2 text-sm text-gray-500"><%= @product.updated_at.strftime("%d/%m/%Y a las %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <div class="mt-4">
    <%= link_to "← Volver a productos", admin_products_path,
          class: "text-sm font-medium text-gray-600 transition-colors hover:text-primary-600" %>
  </div>
</div>
