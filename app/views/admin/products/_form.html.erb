<%= form_with(model: [:admin, product], multipart: true, class: "space-y-6") do |form| %>
  <%# Validation errors %>
  <% if product.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <div class="flex gap-3">
        <span class="shrink-0 text-red-500">⚠</span>
        <div>
          <p class="text-sm font-semibold text-red-800">
            <%= product.errors.count == 1 ? "1 error impidió guardar este producto:" : "#{product.errors.count} errores impidieron guardar este producto:" %>
          </p>
          <ul class="mt-2 list-disc pl-5 text-sm text-red-700 space-y-1">
            <% product.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Core info %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Información del producto</h2>
    </div>
    <div class="p-6 space-y-5">
      <div>
        <%= form.label :name, "Nombre *", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :name,
              placeholder: "Empanada de Carne",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        <p class="mt-1.5 text-xs text-gray-500">El slug se genera automáticamente a partir del nombre.</p>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :collection_id, "Colección *", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.select :collection_id,
                @collections.map { |c| [c.name, c.id] },
                { prompt: "Selecciona una colección" },
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>
        <div>
          <%= form.label :price, "Precio (Q)", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.number_field :price,
                step: 0.01, min: 0,
                placeholder: "0.00",
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>
      </div>

      <div>
        <%= form.label :description, "Descripción", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_area :description,
              rows: 4,
              placeholder: "Describe el producto: ingredientes, sabor, tamaño...",
              class: "block w-full resize-none rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
      </div>
    </div>
  </div>

  <%# Visibility flags %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Estado y visibilidad</h2>
    </div>
    <div class="p-6 space-y-4">
      <div class="flex items-start gap-3">
        <%= form.check_box :active,
              class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer" %>
        <div>
          <%= form.label :active, "Producto activo",
                class: "text-sm font-medium text-gray-700 cursor-pointer" %>
          <p class="mt-0.5 text-xs text-gray-500">Visible en la tienda pública.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <%= form.check_box :featured,
              class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer" %>
        <div>
          <%= form.label :featured, "Destacado",
                class: "text-sm font-medium text-gray-700 cursor-pointer" %>
          <p class="mt-0.5 text-xs text-gray-500">Aparece en la sección "Nuestros Favoritos" del inicio.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <%= form.check_box :seasonal,
              class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500 cursor-pointer" %>
        <div>
          <%= form.label :seasonal, "De temporada",
                class: "text-sm font-medium text-gray-700 cursor-pointer" %>
          <p class="mt-0.5 text-xs text-gray-500">Aparece en la sección estacional del inicio.</p>
        </div>
      </div>
    </div>
  </div>

  <%# Photos %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Fotos</h2>
    </div>
    <div class="p-6 space-y-4">
      <% if product.photos.attached? %>
        <div>
          <p class="mb-3 text-xs font-medium text-gray-500 uppercase tracking-wide">Fotos actuales</p>
          <div class="flex flex-wrap gap-3">
            <% product.photos.each do |photo| %>
              <div class="relative">
                <%= image_tag photo.variant(resize_to_fill: [120, 90]),
                      class: "rounded-lg object-cover shadow-sm ring-1 ring-gray-200",
                      alt: product.name %>
              </div>
            <% end %>
          </div>
          <p class="mt-2 text-xs text-gray-500">Las fotos nuevas se añadirán a las existentes.</p>
        </div>
      <% end %>
      <div>
        <%= form.label :photos, product.photos.attached? ? "Agregar más fotos" : "Subir fotos", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.file_field :photos,
              multiple: true,
              accept: "image/*",
              class: "block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-primary-50 file:px-4 file:py-2 file:text-sm file:font-medium file:text-primary-700 hover:file:bg-primary-100 cursor-pointer" %>
        <p class="mt-1.5 text-xs text-gray-500">Formatos aceptados: JPG, PNG, WebP. Puedes seleccionar varias a la vez.</p>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-between">
    <%= link_to local_assigns[:cancel_path] || admin_products_path,
          class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
      ← Cancelar
    <% end %>
    <%= form.submit class: "inline-flex cursor-pointer items-center rounded-lg bg-primary-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" %>
  </div>
<% end %>
