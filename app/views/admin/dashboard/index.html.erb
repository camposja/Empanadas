<% content_for :title, "Dashboard" %>

<%
  status_classes = {
    "draft"     => "bg-gray-100 text-gray-700",
    "scheduled" => "bg-blue-100 text-blue-800",
    "sending"   => "bg-yellow-100 text-yellow-800",
    "sent"      => "bg-green-100 text-green-800",
    "failed"    => "bg-red-100 text-red-800"
  }
  status_labels = {
    "draft"     => "Borrador",
    "scheduled" => "Programada",
    "sending"   => "Enviando",
    "sent"      => "Enviada",
    "failed"    => "Fallida"
  }
%>

<%# Page header %>
<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">Panel de control</h1>
  <p class="mt-1 text-sm text-gray-500">Gestiona tu tienda desde aquí.</p>
</div>

<%# ── At-a-glance stats ───────────────────────────────────────────── %>
<div class="mb-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Productos activos</p>
    <p class="mt-2 text-3xl font-bold text-primary-600"><%= @stats[:active_products] %></p>
    <p class="mt-0.5 text-xs text-gray-400">en el catálogo</p>
  </div>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Contactos</p>
    <p class="mt-2 text-3xl font-bold text-primary-600"><%= @stats[:total_contacts] %></p>
    <p class="mt-0.5 text-xs text-gray-400"><%= @stats[:opted_in_contacts] %> con opt-in activo</p>
  </div>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Colecciones</p>
    <p class="mt-2 text-3xl font-bold text-primary-600"><%= @stats[:total_collections] %></p>
    <p class="mt-0.5 text-xs text-gray-400">temporadas y líneas</p>
  </div>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Campañas</p>
    <p class="mt-2 text-3xl font-bold text-primary-600"><%= @stats[:total_campaigns] %></p>
    <p class="mt-0.5 text-xs text-gray-400"><%= @stats[:active_campaigns] %> activa<%= @stats[:active_campaigns] == 1 ? "" : "s" %></p>
  </div>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Mensajes enviados</p>
    <p class="mt-2 text-3xl font-bold text-green-600"><%= @stats[:total_messages_sent] %></p>
    <p class="mt-0.5 text-xs text-gray-400">total enviados/entregados</p>
  </div>
  <% if @stats[:total_messages_failed] > 0 %>
    <div class="overflow-hidden rounded-xl border border-red-200 bg-red-50 p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wide text-red-500">Mensajes fallidos</p>
      <p class="mt-2 text-3xl font-bold text-red-600"><%= @stats[:total_messages_failed] %></p>
      <p class="mt-0.5 text-xs text-red-400"><%= link_to "Ver detalles", admin_messages_path(status: "failed"), class: "underline hover:text-red-600" %></p>
    </div>
  <% end %>
</div>

<%# ── Navigation tiles ───────────────────────────────────────────── %>
<div class="mb-8">
  <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-gray-500">Secciones</h2>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">

    <%# Contactos %>
    <%= link_to admin_contacts_path,
          class: "group flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md" do %>
      <div class="mb-4 text-3xl" aria-hidden="true">📋</div>
      <div class="flex-1">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">Contactos</h3>
        <p class="mt-1 text-sm text-gray-500">
          Gestiona la lista de contactos para tus campañas de WhatsApp.
        </p>
        <p class="mt-3 text-xs font-medium text-primary-600">
          <%= @stats[:total_contacts] %> contacto<%= @stats[:total_contacts] == 1 ? "" : "s" %>
        </p>
      </div>
      <div class="mt-4 flex items-center text-sm font-medium text-primary-600 group-hover:text-primary-700 transition-colors">
        Gestionar <span class="ml-1" aria-hidden="true">→</span>
      </div>
    <% end %>

    <%# Productos %>
    <%= link_to admin_products_path,
          class: "group flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md" do %>
      <div class="mb-4 text-3xl" aria-hidden="true">🫓</div>
      <div class="flex-1">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">Productos</h3>
        <p class="mt-1 text-sm text-gray-500">
          Mantén actualizado el catálogo completo de empanadas y precios.
        </p>
        <p class="mt-3 text-xs font-medium text-primary-600">
          <%= @stats[:active_products] %> producto<%= @stats[:active_products] == 1 ? "" : "s" %> activo<%= @stats[:active_products] == 1 ? "" : "s" %>
        </p>
      </div>
      <div class="mt-4 flex items-center text-sm font-medium text-primary-600 group-hover:text-primary-700 transition-colors">
        Gestionar <span class="ml-1" aria-hidden="true">→</span>
      </div>
    <% end %>

    <%# Colecciones %>
    <%= link_to admin_collections_path,
          class: "group flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md" do %>
      <div class="mb-4 text-3xl" aria-hidden="true">📂</div>
      <div class="flex-1">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">Colecciones</h3>
        <p class="mt-1 text-sm text-gray-500">
          Organiza temporadas: Tradicionales, Navidad, Pascua y más.
        </p>
        <p class="mt-3 text-xs font-medium text-primary-600">
          <%= @stats[:total_collections] %> colección<%= @stats[:total_collections] == 1 ? "" : "es" %>
        </p>
      </div>
      <div class="mt-4 flex items-center text-sm font-medium text-primary-600 group-hover:text-primary-700 transition-colors">
        Gestionar <span class="ml-1" aria-hidden="true">→</span>
      </div>
    <% end %>

    <%# Campañas %>
    <%= link_to admin_campaigns_path,
          class: "group flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md" do %>
      <div class="mb-4 text-3xl" aria-hidden="true">📣</div>
      <div class="flex-1">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">Campañas</h3>
        <p class="mt-1 text-sm text-gray-500">
          Crea y programa envíos masivos de WhatsApp a tus contactos.
        </p>
        <p class="mt-3 text-xs font-medium text-primary-600">
          <%= @stats[:total_campaigns] %> campaña<%= @stats[:total_campaigns] == 1 ? "" : "s" %>
        </p>
      </div>
      <div class="mt-4 flex items-center text-sm font-medium text-primary-600 group-hover:text-primary-700 transition-colors">
        Gestionar <span class="ml-1" aria-hidden="true">→</span>
      </div>
    <% end %>

    <%# Mensajes %>
    <%= link_to admin_messages_path,
          class: "group flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-primary-200 hover:shadow-md" do %>
      <div class="mb-4 text-3xl" aria-hidden="true">📨</div>
      <div class="flex-1">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">Mensajes</h3>
        <p class="mt-1 text-sm text-gray-500">
          Revisa el historial de envíos, entregas y errores.
        </p>
        <p class="mt-3 text-xs font-medium text-primary-600">
          <%= @stats[:total_messages_sent] %> enviado<%= @stats[:total_messages_sent] == 1 ? "" : "s" %>
        </p>
      </div>
      <div class="mt-4 flex items-center text-sm font-medium text-primary-600 group-hover:text-primary-700 transition-colors">
        Ver historial <span class="ml-1" aria-hidden="true">→</span>
      </div>
    <% end %>

  </div>
</div>

<%# ── Recent campaigns ───────────────────────────────────────────── %>
<% if @stats[:recent_campaigns].any? %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Campañas recientes</h2>
      <%= link_to "Ver todas", admin_campaigns_path,
            class: "text-xs font-medium text-primary-600 hover:text-primary-700 transition-colors" %>
    </div>
    <table class="min-w-full divide-y divide-gray-100">
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @stats[:recent_campaigns].each do |campaign| %>
          <tr class="transition-colors hover:bg-gray-50">
            <td class="px-6 py-3">
              <p class="text-sm font-medium text-gray-900"><%= campaign.name %></p>
              <p class="mt-0.5 text-xs text-gray-500 line-clamp-1"><%= campaign.message_template %></p>
            </td>
            <td class="whitespace-nowrap px-6 py-3">
              <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium <%= status_classes[campaign.status] %>">
                <%= status_labels[campaign.status] || campaign.status %>
              </span>
            </td>
            <td class="whitespace-nowrap px-6 py-3 text-right text-xs text-gray-400">
              <%= campaign.created_at.strftime("%d/%m/%Y") %>
            </td>
            <td class="whitespace-nowrap px-6 py-3 text-right">
              <%= link_to "Ver", [:admin, campaign],
                    class: "rounded bg-white px-2 py-1 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 transition-colors hover:bg-gray-50" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# ── Recent failed messages ──────────────────────────────────────── %>
<% if @stats[:recent_failed_messages].any? %>
  <div class="mt-6 overflow-hidden rounded-xl border border-red-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-red-100 bg-red-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-red-700">Mensajes fallidos recientes</h2>
      <%= link_to "Ver todos", admin_messages_path(status: "failed"),
            class: "text-xs font-medium text-red-600 hover:text-red-700 transition-colors" %>
    </div>
    <table class="min-w-full divide-y divide-gray-100">
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @stats[:recent_failed_messages].each do |message| %>
          <tr class="bg-red-50/30">
            <td class="px-6 py-3">
              <p class="text-sm font-medium text-gray-900"><%= message.contact.full_name %></p>
              <p class="mt-0.5 text-xs text-gray-500"><%= message.campaign.name %></p>
            </td>
            <td class="px-6 py-3 max-w-xs">
              <p class="text-xs text-red-600"><%= message.error_text %></p>
            </td>
            <td class="whitespace-nowrap px-6 py-3 text-right text-xs text-gray-400">
              <%= message.created_at.strftime("%d/%m/%Y %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
