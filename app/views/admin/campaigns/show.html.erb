<% content_for :title, @campaign.name %>

<%
  status_classes = {
    "draft"     => "bg-gray-100 text-gray-700",
    "scheduled" => "bg-blue-100 text-blue-800",
    "sending"   => "bg-yellow-100 text-yellow-800",
    "sent"      => "bg-green-100 text-green-800",
    "failed"    => "bg-red-100 text-red-800"
  }
  status_labels = {
    "draft"     => "Borrador",
    "scheduled" => "Programada",
    "sending"   => "Enviando",
    "sent"      => "Enviada",
    "failed"    => "Fallida"
  }
%>

<div class="max-w-4xl">
  <%# Breadcrumb + header %>
  <div class="mb-6">
    <nav class="mb-1 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Campañas", admin_campaigns_path, class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-gray-900"><%= @campaign.name %></span>
    </nav>
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold text-gray-900"><%= @campaign.name %></h1>
        <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-medium <%= status_classes[@campaign.status] %>">
          <%= status_labels[@campaign.status] || @campaign.status %>
        </span>
      </div>
      <div class="flex items-center gap-2">
        <% if @campaign.ready_to_send? %>
          <%= button_to "Enviar ahora", send_campaign_admin_campaign_path(@campaign),
                method: :post,
                class: "inline-flex cursor-pointer items-center rounded-lg bg-green-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-green-700",
                data: { turbo_confirm: "¿Enviar la campaña \"#{@campaign.name}\" a #{@campaign.target_contacts.count} contacto(s)?" } %>
        <% end %>
        <%= link_to "Editar", edit_admin_campaign_path(@campaign),
              class: "inline-flex items-center rounded-lg bg-primary-500 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-600" %>
        <%= button_to "Eliminar", [:admin, @campaign],
              method: :delete,
              class: "inline-flex cursor-pointer items-center rounded-lg bg-white px-4 py-2.5 text-sm font-medium text-red-600 shadow-sm ring-1 ring-inset ring-red-200 transition-colors hover:bg-red-50",
              data: { turbo_confirm: "¿Eliminar la campaña \"#{@campaign.name}\"? Esta acción no se puede deshacer." } %>
      </div>
    </div>
  </div>

  <%# Stats row (only if sent/failed > 0) %>
  <% if @campaign.sent_count > 0 || @campaign.failed_count > 0 %>
    <div class="mb-6 grid grid-cols-2 gap-4">
      <div class="rounded-xl border border-green-200 bg-green-50 p-4 text-center">
        <p class="text-2xl font-bold text-green-700"><%= @campaign.sent_count %></p>
        <p class="text-xs font-medium text-green-600 mt-0.5">Mensajes enviados</p>
      </div>
      <div class="rounded-xl border border-red-200 bg-red-50 p-4 text-center">
        <p class="text-2xl font-bold text-red-700"><%= @campaign.failed_count %></p>
        <p class="text-xs font-medium text-red-600 mt-0.5">Mensajes fallidos</p>
      </div>
    </div>
  <% end %>

  <%# Message preview %>
  <div class="mb-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Vista previa del mensaje</h2>
    </div>
    <div class="p-6">
      <div class="rounded-2xl rounded-tl-none bg-green-100 p-4 max-w-sm shadow-sm">
        <p class="text-sm text-gray-800 whitespace-pre-wrap"><%= @campaign.message_template %></p>
      </div>
      <p class="mt-3 text-xs text-gray-400">
        Las variables como <code class="rounded bg-gray-100 px-1">{{first_name}}</code> se reemplazarán al enviar.
      </p>
    </div>
  </div>

  <%# Campaign details %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Detalles de la campaña</h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Tipo</dt>
        <dd class="col-span-2">
          <span class="inline-flex rounded-full bg-purple-50 px-2.5 py-0.5 text-xs font-medium text-purple-700">
            <%= @campaign.type_label %>
          </span>
          <% if @campaign.active? %>
            <span class="ml-1 inline-flex rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Activa</span>
          <% else %>
            <span class="ml-1 inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">Inactiva</span>
          <% end %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Estado</dt>
        <dd class="col-span-2">
          <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium <%= status_classes[@campaign.status] %>">
            <%= status_labels[@campaign.status] || @campaign.status %>
          </span>
        </dd>
      </div>
      <% if @campaign.recurring? %>
        <div class="grid grid-cols-3 gap-4 px-6 py-4">
          <dt class="text-sm font-medium text-gray-500">Frecuencia</dt>
          <dd class="col-span-2 text-sm text-gray-900">
            Cada <%= @campaign.recurring_interval_days %> día<%= @campaign.recurring_interval_days == 1 ? "" : "s" %>
          </dd>
        </div>
        <div class="grid grid-cols-3 gap-4 px-6 py-4">
          <dt class="text-sm font-medium text-gray-500">Último envío</dt>
          <dd class="col-span-2 text-sm text-gray-900">
            <%= @campaign.last_sent_at ? @campaign.last_sent_at.strftime("%d/%m/%Y a las %H:%M") : "Nunca" %>
          </dd>
        </div>
        <% if @campaign.next_recurring_send_at %>
          <div class="grid grid-cols-3 gap-4 px-6 py-4">
            <dt class="text-sm font-medium text-gray-500">Próximo envío</dt>
            <dd class="col-span-2 text-sm text-gray-900">
              <% next_at = @campaign.next_recurring_send_at %>
              <% if next_at <= Time.current %>
                <span class="text-green-700 font-medium">Pendiente (se enviará en el próximo ciclo)</span>
              <% else %>
                <%= next_at.strftime("%d/%m/%Y") %>
              <% end %>
            </dd>
          </div>
        <% end %>
      <% end %>
      <% if @campaign.starts_on.present? || @campaign.ends_on.present? %>
        <div class="grid grid-cols-3 gap-4 px-6 py-4">
          <dt class="text-sm font-medium text-gray-500">Período</dt>
          <dd class="col-span-2 text-sm text-gray-900">
            <%= @campaign.starts_on&.strftime("%d/%m/%Y") || "—" %> → <%= @campaign.ends_on&.strftime("%d/%m/%Y") || "sin fin" %>
          </dd>
        </div>
      <% end %>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Programada para</dt>
        <dd class="col-span-2 text-sm text-gray-900">
          <%= @campaign.scheduled_for ? @campaign.scheduled_for.strftime("%d/%m/%Y a las %H:%M") : "—" %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Segmento</dt>
        <dd class="col-span-2 text-sm text-gray-900">
          <% if @campaign.segment_tags.present? %>
            <div class="flex flex-wrap gap-1.5">
              <% @campaign.segment_tags.split(",").map(&:strip).each do |tag| %>
                <span class="inline-flex rounded-md bg-primary-50 px-2 py-0.5 text-xs font-medium text-primary-700"><%= tag %></span>
              <% end %>
            </div>
          <% else %>
            <span class="text-gray-400">Todos los contactos con opt-in activo</span>
          <% end %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Registrada</dt>
        <dd class="col-span-2 text-sm text-gray-500"><%= @campaign.created_at.strftime("%d/%m/%Y a las %H:%M") %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Actualizada</dt>
        <dd class="col-span-2 text-sm text-gray-500"><%= @campaign.updated_at.strftime("%d/%m/%Y a las %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Audience preview %>
  <div class="mt-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Audiencia objetivo</h2>
    </div>
    <div class="px-6 py-4">
      <% target_count = @campaign.target_contacts.count %>
      <p class="text-sm text-gray-900">
        <span class="text-2xl font-bold text-primary-600"><%= target_count %></span>
        contacto<%= target_count == 1 ? "" : "s" %> recibirán esta campaña
      </p>
      <% if @campaign.segment_tags.blank? %>
        <p class="mt-1 text-xs text-gray-500">Todos los contactos con opt-in activo.</p>
      <% end %>
    </div>
  </div>

  <%# Recent messages for this campaign %>
  <% if @recent_messages.any? %>
    <div class="mt-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-gray-100 bg-gray-50 px-6 py-4">
        <h2 class="text-sm font-semibold text-gray-700">Mensajes recientes</h2>
        <%= link_to "Ver todos", admin_messages_path(campaign_id: @campaign.id),
              class: "text-xs font-medium text-primary-600 hover:text-primary-700 transition-colors" %>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-100">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Contacto</th>
              <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Estado</th>
              <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Fecha</th>
              <th scope="col" class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Error</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% msg_status_classes = { "pending" => "bg-gray-100 text-gray-700", "queued" => "bg-blue-100 text-blue-800", "sent" => "bg-green-100 text-green-800", "delivered" => "bg-green-100 text-green-800", "failed" => "bg-red-100 text-red-800" } %>
            <% msg_status_labels = { "pending" => "Pendiente", "queued" => "En cola", "sent" => "Enviado", "delivered" => "Entregado", "failed" => "Fallido" } %>
            <% @recent_messages.each do |message| %>
              <tr class="transition-colors hover:bg-gray-50 <%= message.status == 'failed' ? 'bg-red-50/50' : '' %>">
                <td class="whitespace-nowrap px-5 py-2.5">
                  <p class="text-sm font-medium text-gray-900"><%= message.contact.full_name %></p>
                  <p class="text-xs text-gray-500 font-mono"><%= message.contact.phone_number %></p>
                </td>
                <td class="whitespace-nowrap px-5 py-2.5">
                  <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium <%= msg_status_classes[message.status] %>">
                    <%= msg_status_labels[message.status] || message.status %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-5 py-2.5 text-xs text-gray-500">
                  <%= message.created_at.strftime("%d/%m/%Y %H:%M") %>
                </td>
                <td class="px-5 py-2.5 max-w-xs">
                  <% if message.error_text.present? %>
                    <p class="text-xs text-red-600"><%= message.error_text %></p>
                  <% else %>
                    <span class="text-xs text-gray-400">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to "← Volver a campañas", admin_campaigns_path,
          class: "text-sm font-medium text-gray-600 transition-colors hover:text-primary-600" %>
  </div>
</div>
