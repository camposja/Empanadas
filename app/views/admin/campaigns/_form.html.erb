<%= form_with(model: [:admin, campaign], class: "space-y-6") do |form| %>
  <%# Validation errors %>
  <% if campaign.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4">
      <div class="flex gap-3">
        <span class="shrink-0 text-red-500">⚠</span>
        <div>
          <p class="text-sm font-semibold text-red-800">
            <%= campaign.errors.count == 1 ? "1 error impidió guardar esta campaña:" : "#{campaign.errors.count} errores impidieron guardar esta campaña:" %>
          </p>
          <ul class="mt-2 list-disc pl-5 text-sm text-red-700 space-y-1">
            <% campaign.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Configuration %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Configuración de la campaña</h2>
    </div>
    <div class="p-6 space-y-5">
      <div>
        <%= form.label :name, "Nombre de la campaña *", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :name,
              placeholder: "Ej: Promoción Navidad 2025",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :status, "Estado", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.select :status,
                [["Borrador", "draft"], ["Programada", "scheduled"], ["Enviando", "sending"], ["Enviada", "sent"], ["Fallida", "failed"]],
                {},
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        </div>
        <div>
          <%= form.label :scheduled_for, "Programada para", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.datetime_local_field :scheduled_for,
                class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
          <p class="mt-1.5 text-xs text-gray-500">Requerido solo cuando el estado es "Programada".</p>
        </div>
      </div>
    </div>
  </div>

  <%# Message %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Mensaje</h2>
    </div>
    <div class="p-6 space-y-4">
      <div>
        <%= form.label :message_template, "Plantilla del mensaje *", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_area :message_template,
              rows: 6,
              placeholder: "Hola {{first_name}}! Tenemos novedades para ti en EmpanadArte 🥟",
              class: "block w-full resize-none rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
      </div>
      <div class="rounded-lg bg-blue-50 border border-blue-100 p-3">
        <p class="text-xs font-semibold text-blue-800 mb-1.5">Variables disponibles:</p>
        <div class="flex flex-wrap gap-1.5">
          <code class="rounded bg-white px-2 py-0.5 text-xs text-blue-700 ring-1 ring-blue-200">{{first_name}}</code>
          <code class="rounded bg-white px-2 py-0.5 text-xs text-blue-700 ring-1 ring-blue-200">{{last_name}}</code>
          <code class="rounded bg-white px-2 py-0.5 text-xs text-blue-700 ring-1 ring-blue-200">{{phone_number}}</code>
        </div>
      </div>
    </div>
  </div>

  <%# Audience %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-4">
      <h2 class="text-sm font-semibold text-gray-700">Audiencia</h2>
    </div>
    <div class="p-6">
      <div>
        <%= form.label :segment_tags, "Etiquetas de segmento", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :segment_tags,
              placeholder: "vip, navidad, regular",
              class: "block w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" %>
        <p class="mt-1.5 text-xs text-gray-500">
          Separa etiquetas con comas. Si se deja en blanco, la campaña se envía a todos los contactos con opt-in activo.
        </p>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-between">
    <%= link_to local_assigns[:cancel_path] || admin_campaigns_path,
          class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
      ← Cancelar
    <% end %>
    <%= form.submit class: "inline-flex cursor-pointer items-center rounded-lg bg-primary-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2" %>
  </div>
<% end %>
