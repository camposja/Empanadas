<% content_for :title, "Editar — #{@campaign.name}" %>

<div class="max-w-2xl">
  <div class="mb-6">
    <nav class="mb-1 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Campañas", admin_campaigns_path, class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <%= link_to @campaign.name, [:admin, @campaign], class: "transition-colors hover:text-primary-600" %>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-gray-900">Editar</span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900">Editar campaña</h1>
  </div>

  <%= render "form", campaign: @campaign, cancel_path: [:admin, @campaign] %>
</div>
