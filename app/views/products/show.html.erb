<% content_for :title, @product.name %>
<% content_for :description, @product.description.present? ? @product.description.truncate(155) : "#{@product.name} — Empanada artesanal guatemalteca. Ordena por WhatsApp." %>

<%# ====================================================
    BREADCRUMB + HEADER
    ==================================================== %>
<div class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-gray-500 flex-wrap">
        <li><%= link_to "Inicio", root_path, class: "hover:text-primary-600 transition-colors" %></li>
        <li aria-hidden="true"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
        <li><%= link_to "Productos", products_path, class: "hover:text-primary-600 transition-colors" %></li>
        <% if @product.collection %>
          <li aria-hidden="true"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
          <li>
            <%= link_to @product.collection.name,
                products_path(collection_id: @product.collection.id),
                class: "hover:text-primary-600 transition-colors" %>
          </li>
        <% end %>
        <li aria-hidden="true"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-gray-900 font-medium line-clamp-1" aria-current="page"><%= @product.name %></li>
      </ol>
    </nav>
  </div>
</div>

<%# ====================================================
    PRODUCT DETAIL
    ==================================================== %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="lg:grid lg:grid-cols-5 lg:gap-12 items-start">

    <%# LEFT: Image gallery (3 of 5 cols on lg) %>
    <div class="lg:col-span-3 mb-8 lg:mb-0" data-controller="gallery">
      <%# Main image %>
      <div class="relative overflow-hidden rounded-2xl bg-primary-50 aspect-[4/3]">
        <% if @product.photos.attached? %>
          <%= image_tag @product.photos.first.variant(resize_to_fill: [800, 600]),
              alt: @product.name,
              id: "main-product-image",
              class: "w-full h-full object-cover",
              data: { gallery_target: "main" } %>
        <% else %>
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-100 to-cream-200"
               data-gallery-target="main">
            <span class="text-8xl opacity-70" aria-hidden="true">🫓</span>
          </div>
        <% end %>

        <%# Badges overlay %>
        <div class="absolute top-4 left-4 flex flex-col gap-2">
          <% if @product.featured? %>
            <span class="inline-flex items-center gap-1 bg-amber-500 text-white text-sm font-semibold px-3 py-1.5 rounded-full shadow-md">
              ★ Destacado
            </span>
          <% end %>
          <% if @product.seasonal? %>
            <span class="inline-flex items-center gap-1 bg-emerald-600 text-white text-sm font-semibold px-3 py-1.5 rounded-full shadow-md">
              🍂 De Temporada
            </span>
          <% end %>
        </div>
      </div>

      <%# Thumbnails row (shown only if more than 1 photo) %>
      <% if @product.photos.count > 1 %>
        <div class="mt-4 grid grid-cols-4 gap-3">
          <% @product.photos.each_with_index do |photo, index| %>
            <button type="button"
                    class="rounded-xl overflow-hidden border-2 border-transparent hover:border-primary-400 transition-colors focus:border-primary-500 aspect-square"
                    data-action="gallery#swap"
                    data-src="<%= url_for(photo.variant(resize_to_fill: [800, 600])) %>"
                    aria-label="Ver foto <%= index + 1 %>">
              <%= image_tag photo.variant(resize_to_fill: [150, 150]),
                  alt: "#{@product.name} foto #{index + 1}",
                  class: "w-full h-full object-cover",
                  loading: "lazy" %>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# RIGHT: Product info (2 of 5 cols on lg) %>
    <div class="lg:col-span-2 lg:sticky lg:top-24">
      <% if @product.collection %>
        <span class="text-xs font-semibold uppercase tracking-widest text-primary-500 mb-2 block">
          <%= @product.collection.name %>
        </span>
      <% end %>

      <h1 class="font-display font-bold text-gray-900 text-3xl sm:text-4xl leading-tight mb-4">
        <%= @product.name %>
      </h1>

      <div class="flex items-baseline gap-3 mb-6">
        <span class="text-primary-600 font-bold text-4xl">
          <%= format_price(@product.price) %>
        </span>
      </div>

      <% if @product.description.present? %>
        <p class="text-gray-600 leading-relaxed mb-8 text-base">
          <%= @product.description %>
        </p>
      <% end %>

      <%# WhatsApp order button %>
      <a href="<%= whatsapp_order_url(@product) %>"
         target="_blank"
         rel="noopener noreferrer"
         class="flex items-center justify-center gap-3 w-full bg-whatsapp hover:bg-whatsapp-dark text-white font-bold text-lg px-6 py-4 rounded-2xl transition-colors shadow-md mb-4">
        <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Ordenar por WhatsApp
      </a>

      <p class="text-center text-gray-400 text-xs">
        Te responderemos en menos de 1 hora en horario de atención.
      </p>
    </div>
  </div>
</div>

<%# ====================================================
    RELATED PRODUCTS
    ==================================================== %>
<% if @related_products.any? %>
  <section class="py-12 bg-cream-100 border-t border-cream-200" aria-labelledby="related-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="related-heading" class="font-display font-bold text-gray-900 text-2xl sm:text-3xl mb-8">
        También te puede gustar
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% @related_products.each do |product| %>
          <%= render "shared/product_card", product: product %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
