<% content_for :title, "Todos los Productos" %>
<% content_for :description, "Explora nuestro catálogo completo de empanadas artesanales guatemaltecas. Tradicionales, navideñas y de temporada." %>

<%# Page header %>
<div class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav aria-label="Breadcrumb" class="mb-4">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><%= link_to "Inicio", root_path, class: "hover:text-primary-600 transition-colors" %></li>
        <li aria-hidden="true"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-gray-900 font-medium" aria-current="page">Productos</li>
      </ol>
    </nav>

    <h1 class="font-display font-bold text-gray-900 text-3xl sm:text-4xl mb-2">
      Todos los Productos
    </h1>
    <p class="text-gray-500">
      <%= pluralize(@products.count, "producto disponible", "productos disponibles") %>
    </p>
  </div>
</div>

<%# Collection filter bar %>
<% if @collections.any? %>
  <div class="bg-white sticky top-16 z-40 border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 py-3 overflow-x-auto" role="tablist" aria-label="Filtrar por colección">
        <%= link_to products_path,
            class: "flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:collection_id].blank? ? 'bg-primary-500 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-primary-50 hover:text-primary-700'}",
            role: "tab",
            "aria-selected": params[:collection_id].blank? ? "true" : "false" do %>
          Todos
        <% end %>

        <% @collections.each do |collection| %>
          <%= link_to products_path(collection_id: collection.id),
              class: "flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:collection_id].to_s == collection.id.to_s ? 'bg-primary-500 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-primary-50 hover:text-primary-700'}",
              role: "tab",
              "aria-selected": params[:collection_id].to_s == collection.id.to_s ? "true" : "false" do %>
            <%= collection.name %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# Product grid %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <% if @products.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @products.each do |product| %>
        <%= render "shared/product_card", product: product %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-24">
      <div class="text-6xl mb-6" aria-hidden="true">🍽️</div>
      <h2 class="font-display font-bold text-gray-900 text-2xl mb-3">
        No hay productos en esta colección
      </h2>
      <p class="text-gray-500 mb-6">Intenta seleccionar otra colección o ver todos los productos.</p>
      <%= link_to "Ver todos los productos", products_path,
          class: "inline-flex items-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
    </div>
  <% end %>
</div>
