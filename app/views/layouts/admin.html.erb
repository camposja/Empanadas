<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} | Admin — EmpanadArte" : "Admin — EmpanadArte" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <%# Admin nav %>
    <nav class="bg-primary-900 text-white shadow-sm" aria-label="Admin navigation">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center gap-6">
            <span class="font-bold text-cream-100 text-sm">🫓 Admin Panel</span>
            <div class="hidden sm:flex items-center gap-1 text-sm">
              <%= link_to "Dashboard", admin_root_path, class: "px-3 py-1.5 rounded text-primary-200 hover:text-white hover:bg-primary-800 transition-colors" %>
              <%= link_to "Productos", admin_products_path, class: "px-3 py-1.5 rounded text-primary-200 hover:text-white hover:bg-primary-800 transition-colors" %>
              <%= link_to "Colecciones", admin_collections_path, class: "px-3 py-1.5 rounded text-primary-200 hover:text-white hover:bg-primary-800 transition-colors" %>
              <%= link_to "Contactos", admin_contacts_path, class: "px-3 py-1.5 rounded text-primary-200 hover:text-white hover:bg-primary-800 transition-colors" %>
              <%= link_to "Campañas", admin_campaigns_path, class: "px-3 py-1.5 rounded text-primary-200 hover:text-white hover:bg-primary-800 transition-colors" %>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <%= link_to "Ver tienda", root_path, target: "_blank", class: "text-xs text-primary-300 hover:text-white transition-colors" %>
            <%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs text-primary-300 hover:text-white transition-colors" %>
          </div>
        </div>
      </div>
    </nav>

    <%# Flash messages %>
    <% flash.each do |type, message| %>
      <% color = type.to_s == "notice" ? "bg-green-50 border-green-200 text-green-800" : "bg-red-50 border-red-200 text-red-800" %>
      <div class="border-l-4 <%= color %> px-4 py-3 text-sm" role="alert">
        <%= message %>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
