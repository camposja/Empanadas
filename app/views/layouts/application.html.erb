<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} | Tienda Empanadas" : "Tienda Empanadas — Las mejores empanadas de Guatemala" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Las mejores empanadas artesanales de Guatemala. Pide por WhatsApp y recíbelas en casa." %>">

    <%# Open Graph basics %>
    <meta property="og:title" content="<%= content_for?(:title) ? "#{yield(:title)} | Tienda Empanadas" : "Tienda Empanadas" %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : "Las mejores empanadas artesanales de Guatemala." %>">
    <meta property="og:type" content="website">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tienda Empanadas">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-cream-50 text-gray-900 font-sans antialiased">
    <%= render "shared/navbar" %>
    <%= render "shared/flash_messages" %>
    <main>
      <%= yield %>
    </main>
    <%= render "shared/footer" %>
  </body>
</html>
