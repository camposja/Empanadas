<% content_for :title, "Inicio" %>
<% content_for :description, "EmpanadArte: empanadas y comida artesanal de Guatemala. Tradicionales, navideñas y de temporada. Pide por WhatsApp y recíbelas en casa." %>

<%# ====================================================
    HERO SECTION
    ==================================================== %>
<section class="relative overflow-hidden bg-gradient-to-br from-cream-50 via-cream-100 to-primary-100 min-h-[65vh] flex items-center"
         aria-labelledby="hero-heading">
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-primary-200/30 blur-3xl"></div>
    <div class="absolute -bottom-16 -left-16 w-72 h-72 rounded-full bg-cream-300/50 blur-2xl"></div>
    <div class="absolute top-1/2 left-1/3 w-64 h-64 rounded-full bg-primary-100/40 blur-2xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-6 border border-primary-200">
        <span aria-hidden="true">🇬🇹</span>
        100% Guatemaltecas y artesanales
      </span>

      <h1 id="hero-heading" class="font-display font-bold text-gray-900 text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
        <span class="text-primary-800">Empanad</span><span class="text-primary-400">Arte</span><br>
        <span class="text-primary-500">Empanada y comida</span><br>
        Artesanal <span aria-hidden="true">🥟</span>
      </h1>

      <p class="text-gray-600 text-lg sm:text-xl leading-relaxed mb-8 max-w-lg">
        Hechas con amor y recetas de toda la vida. Pide fácil por WhatsApp y recíbelas en casa.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= link_to products_path,
            class: "inline-flex items-center justify-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold px-7 py-3.5 rounded-xl transition-colors text-base shadow-sm" do %>
          Ver todos los productos
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>

        <a href="https://wa.me/50230016011"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-2 bg-whatsapp hover:bg-whatsapp-dark text-white font-semibold px-7 py-3.5 rounded-xl transition-colors text-base shadow-sm">
          <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Ordenar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<%# ====================================================
    FEATURED PRODUCTS SECTION
    ==================================================== %>
<% if @featured_products.any? %>
  <section class="py-16 bg-white" aria-labelledby="featured-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <span class="text-primary-500 text-sm font-semibold uppercase tracking-widest mb-1 block">Lo más popular</span>
          <h2 id="featured-heading" class="font-display font-bold text-gray-900 text-3xl sm:text-4xl">
            Nuestros Favoritos ⭐
          </h2>
          <p class="text-gray-500 mt-2">Seleccionados con cariño para ti</p>
        </div>
        <%= link_to products_path,
            class: "text-primary-600 hover:text-primary-700 font-semibold text-sm flex items-center gap-1 flex-shrink-0 transition-colors" do %>
          Ver todos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @featured_products.each do |product| %>
          <%= render "shared/product_card", product: product %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ====================================================
    SEASONAL SECTION
    ==================================================== %>
<% if @seasonal_products.any? %>
  <section class="py-16 bg-primary-50 border-y border-primary-100" aria-labelledby="seasonal-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <span class="text-primary-500 text-sm font-semibold uppercase tracking-widest mb-1 block">Disponibles ahora</span>
          <h2 id="seasonal-heading" class="font-display font-bold text-gray-900 text-3xl sm:text-4xl">
            De Temporada 🍂
          </h2>
          <p class="text-gray-500 mt-2">¡Apúrate antes que se agoten!</p>
        </div>
        <%= link_to products_path,
            class: "text-primary-600 hover:text-primary-700 font-semibold text-sm flex items-center gap-1 flex-shrink-0 transition-colors" do %>
          Ver todos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% @seasonal_products.each do |product| %>
          <%= render "shared/product_card", product: product %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ====================================================
    COLLECTIONS SECTION
    ==================================================== %>
<% if @collections.any? %>
  <section class="py-16 bg-cream-100" aria-labelledby="collections-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-primary-500 text-sm font-semibold uppercase tracking-widest mb-1 block">Para cada ocasión</span>
      <h2 id="collections-heading" class="font-display font-bold text-gray-900 text-3xl sm:text-4xl mb-3">
        Explora por Colección
      </h2>
      <p class="text-gray-500 mb-10 max-w-md mx-auto">
        Desde las tradicionales guatemaltecas hasta las especiales de temporada.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <% @collections.each do |collection| %>
          <%= link_to collection_path(collection),
              class: "group bg-white hover:bg-primary-500 text-gray-800 hover:text-white font-semibold px-6 py-4 rounded-2xl shadow-sm hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-primary-500 min-w-[160px] text-center" do %>
            <div class="text-3xl mb-2" aria-hidden="true">
              <%= case collection.name.downcase
                  when /navidad/ then "🎄"
                  when /thanksgiving/ then "🦃"
                  when /tradicional/ then "🫓"
                  else "🍽️"
                  end %>
            </div>
            <div class="font-display font-bold text-lg"><%= collection.name %></div>
            <% if collection.description.present? %>
              <div class="text-xs mt-1 opacity-70 line-clamp-2 group-hover:opacity-90">
                <%= collection.description %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ====================================================
    WHY US SECTION
    ==================================================== %>
<section class="py-16 bg-white" aria-labelledby="why-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="why-heading" class="font-display font-bold text-gray-900 text-3xl sm:text-4xl mb-3">
        ¿Por qué elegirnos?
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div class="text-center px-4">
        <div class="text-5xl mb-4" aria-hidden="true">🌿</div>
        <h3 class="font-display font-bold text-gray-900 text-lg mb-2">Ingredientes frescos</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Usamos ingredientes frescos y locales, comprados cada mañana en el mercado.
        </p>
      </div>
      <div class="text-center px-4">
        <div class="text-5xl mb-4" aria-hidden="true">👩‍🍳</div>
        <h3 class="font-display font-bold text-gray-900 text-lg mb-2">Recetas tradicionales</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Cada empanada se prepara con recetas de familia, transmitidas de generación en generación.
        </p>
      </div>
      <div class="text-center px-4">
        <div class="text-5xl mb-4" aria-hidden="true">🚀</div>
        <h3 class="font-display font-bold text-gray-900 text-lg mb-2">Entrega rápida</h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Pide por WhatsApp y coordina tu entrega en Ciudad de Guatemala. ¡Así de fácil!
        </p>
      </div>
    </div>
  </div>
</section>

<%# ====================================================
    CTA BOTTOM BAND
    ==================================================== %>
<section class="py-14 bg-primary-600" aria-labelledby="cta-heading">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 id="cta-heading" class="font-display font-bold text-white text-3xl sm:text-4xl mb-4">
      ¿Listo para ordenar? 🫓
    </h2>
    <p class="text-primary-100 text-lg mb-8">
      Escríbenos por WhatsApp y te atendemos de inmediato.
    </p>
    <a href="https://wa.me/50230016011"
       target="_blank"
       rel="noopener noreferrer"
       class="inline-flex items-center gap-3 bg-whatsapp hover:bg-whatsapp-dark text-white font-bold px-8 py-4 rounded-2xl transition-colors text-lg shadow-lg">
      <svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
