<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100 shadow-sm"
     aria-label="Navegación principal"
     data-controller="menu">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <%# Logo / Brand %>
      <%= link_to root_path, class: "flex items-center gap-1.5 flex-shrink-0" do %>
        <span class="text-2xl" aria-hidden="true">🥟</span>
        <span class="font-display font-bold text-xl leading-none tracking-tight">
          <span class="text-primary-800">Empanad</span><span class="text-primary-400">Arte</span>
        </span>
        <span class="text-xl" aria-hidden="true">🖌️</span>
      <% end %>

      <%# Desktop nav links %>
      <div class="hidden md:flex items-center gap-1">
        <%= link_to "Inicio", root_path,
            class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" %>
        <%= link_to "Productos", products_path,
            class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" %>

        <%# Collections dropdown — zero JS via <details> %>
        <% if (collections = Collection.active.ordered).any? %>
          <details class="relative group">
            <summary class="list-none px-4 py-2 text-sm font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors cursor-pointer flex items-center gap-1">
              Colecciones
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="absolute top-full left-0 mt-1 w-52 bg-white rounded-xl shadow-lg border border-gray-100 py-1 z-50">
              <% collections.each do |collection| %>
                <%= link_to collection_path(collection),
                    class: "block px-4 py-2.5 text-sm text-gray-700 hover:bg-primary-50 hover:text-primary-700 transition-colors" do %>
                  <%= collection.name %>
                  <% if collection.description.present? %>
                    <span class="block text-xs text-gray-400 mt-0.5 line-clamp-1"><%= collection.description %></span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>

      <%# Right side: WhatsApp CTA + mobile hamburger %>
      <div class="flex items-center gap-3">
        <a href="https://wa.me/50230016011"
           target="_blank"
           rel="noopener noreferrer"
           class="hidden sm:flex items-center gap-2 bg-whatsapp hover:bg-whatsapp-dark text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors shadow-sm">
          <%# WhatsApp SVG icon %>
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="hidden lg:inline">Ordenar por WhatsApp</span>
          <span class="lg:hidden">WhatsApp</span>
        </a>

        <%# Mobile hamburger button %>
        <button type="button"
                class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-600 hover:text-primary-600 hover:bg-primary-50 transition-colors"
                data-action="menu#toggle"
                aria-expanded="false"
                aria-label="Abrir menú">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <%# Mobile dropdown menu %>
  <div class="hidden md:hidden border-t border-gray-100 bg-white" data-menu-target="menu">
    <div class="px-4 py-3 space-y-1">
      <%= link_to "Inicio", root_path,
          class: "block px-3 py-2.5 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" %>
      <%= link_to "Productos", products_path,
          class: "block px-3 py-2.5 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" %>

      <% if (collections = Collection.active.ordered).any? %>
        <div class="pt-1 pb-1">
          <p class="px-3 py-1 text-xs font-semibold text-gray-400 uppercase tracking-wider">Colecciones</p>
          <% collections.each do |collection| %>
            <%= link_to collection.name, collection_path(collection),
                class: "block px-3 py-2.5 text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors" %>
          <% end %>
        </div>
      <% end %>

      <div class="pt-2 pb-1">
        <a href="https://wa.me/50230016011"
           target="_blank"
           rel="noopener noreferrer"
           class="flex items-center justify-center gap-2 w-full bg-whatsapp text-white font-semibold px-4 py-3 rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Ordenar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</nav>
