<% content_for :title, @collection.name %>
<% content_for :description, @collection.description.present? ? @collection.description : "Explora nuestra colección #{@collection.name} de empanadas artesanales guatemaltecas." %>

<%# Collection hero header %>
<div class="bg-primary-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-2 text-sm text-primary-200">
        <li><%= link_to "Inicio", root_path, class: "hover:text-white transition-colors" %></li>
        <li aria-hidden="true"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
        <li><%= link_to "Productos", products_path, class: "hover:text-white transition-colors" %></li>
        <li aria-hidden="true"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-white font-medium" aria-current="page"><%= @collection.name %></li>
      </ol>
    </nav>

    <div class="flex items-center gap-4 mb-4">
      <span class="text-5xl" aria-hidden="true">
        <%= case @collection.name.downcase
            when /navidad/ then "🎄"
            when /thanksgiving/ then "🦃"
            when /tradicional/ then "🫓"
            else "🍽️"
            end %>
      </span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl">
        <%= @collection.name %>
      </h1>
    </div>

    <% if @collection.description.present? %>
      <p class="text-primary-100 text-lg max-w-2xl mb-4">
        <%= @collection.description %>
      </p>
    <% end %>

    <span class="inline-flex items-center bg-primary-600/60 text-primary-100 text-sm font-medium px-4 py-1.5 rounded-full">
      <%= pluralize(@products.count, "producto", "productos") %> disponibles
    </span>
  </div>
</div>

<%# Products grid %>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <% if @products.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @products.each do |product| %>
        <%= render "shared/product_card", product: product %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-24">
      <div class="text-6xl mb-6" aria-hidden="true">🫓</div>
      <h2 class="font-display font-bold text-gray-900 text-2xl mb-3">
        Esta colección está vacía por ahora
      </h2>
      <p class="text-gray-500 mb-6">Vuelve pronto, estamos preparando novedades.</p>
      <%= link_to "Ver todos los productos", products_path,
          class: "inline-flex items-center gap-2 bg-primary-500 hover:bg-primary-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors" %>
    </div>
  <% end %>
</div>

<%# WhatsApp CTA band %>
<section class="py-10 bg-primary-50 border-t border-primary-100">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-gray-700 font-medium mb-4">
      ¿Te gustó algo de la colección <strong><%= @collection.name %></strong>?
    </p>
    <a href="https://wa.me/50230016011?text=<%= URI.encode_www_form_component("Hola! Me interesan las empanadas de la colección #{@collection.name}") %>"
       target="_blank"
       rel="noopener noreferrer"
       class="inline-flex items-center gap-2 bg-whatsapp hover:bg-whatsapp-dark text-white font-semibold px-6 py-3 rounded-xl transition-colors shadow-sm">
      <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Ordenar por WhatsApp
    </a>
  </div>
</section>
